{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "rootDir": ".",
    "strict": true,
    "types": [
      "vitest/globals"
    ],
  },
  "angularCompilerOptions": {
    "strictTemplates": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.spec.ts"
  ]
}